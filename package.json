{
  "name": "jpc-eats",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "sandbox": "ampx sandbox --profile personal",
    "preview": "vite preview",
    "prod-config": "ampx generate outputs --app-id d2d2fy881dt3wt --branch main --profile personal",
    "ios": "npm run prod-config && npm run dev-ios",
    "dev-ios": "npm run build && cap sync && cap copy ios && cap open ios",
    "prepare": "husky install"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.13.2",
    "@aws-amplify/ui-react-geo": "^2.2.13",
    "@aws-sdk/s3-request-presigner": "^3.967.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/geolocation": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.6",
    "@tanstack/react-query": "^5.90.16",
    "aws-amplify": "^6.15.9",
    "aws-lambda": "^1.0.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.6.0",
    "use-debounce": "^10.1.0"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.22.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@aws-sdk/client-dynamodb": "^3.1030.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@eslint/js": "^10.0.1",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/recharts": "^2.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "aws-cdk": "^2.1118.0",
    "aws-cdk-lib": "^2.249.0",
    "constructs": "^10.4.4",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --cache --fix",
      "bash -c 'tsc --noEmit'"
    ],
    "*.json": "prettier --write",
    "*.yml": "prettier --write",
    "*.md": "prettier --write"
  }
}
